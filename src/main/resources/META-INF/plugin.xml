<idea-plugin url="https://plugins.jetbrains.com/plugin/16788-restfultoolkit-fix" allow-bundled-update="true">
    <id>me.jinghong.restful.toolkit</id>
    <name>RestfulToolkit-fix</name>
    <version>2.1.21</version>
    <vendor email="libinjava@qq.com" url="https://github.com/billyle">billyle (原作者: jinghong)</vendor>

    <description><![CDATA[
  <h3>A toolkit for RESTful services development.</h3>
  <ul>
   <li>1. Navigate to service declaration by URL (Ctrl + \ or Ctrl + Alt + N)</li>
   <li>2. RESTful services tree view with multi-level structure:
     <ul>
       <li>Module -> Service Type (Rest/Feign) -> Downstream Service (for Feign) -> Endpoint</li>
     </ul>
   </li>
   <li>3. Simple HTTP request tool with syntax highlighting</li>
   <li>4. Context menu actions: Copy Full URL, Jump to Source</li>
   <li>5. Generate and Copy Query Param, Request Body (JSON), URL</li>
   <li>6. Convert Java class to JSON (Ctrl + Enter to format)</li>
 </ul>
   <p>Support Spring framework (Spring MVC / Spring Boot), Feign Client, JAX-RS</p>
   <p>Support Java and Kotlin languages</p>

  <hr />
  <h3>RESTful services development toolkit.</h3>
  <ul>
   <li>1. Navigate to method definition by URL (Ctrl + \ or Ctrl + Alt + N)</li>
   <li>2. RESTful services tree with multi-level structure:
     <ul>
       <li>Module -> Service Type (Rest/Feign) -> Downstream Service (Feign) -> Endpoint</li>
     </ul>
   </li>
   <li>3. Simple HTTP request tool with syntax highlighting</li>
   <li>4. Context menu: Copy Full URL, Jump to Source</li>
   <li>5. Generate and Copy: Query Param, Request Body (JSON), URL</li>
   <li>6. Java class to JSON (Ctrl + Enter to format)</li>
</ul>
   <p>Support: Spring MVC/Boot, Feign Client, JAX-RS</p>
   <p>Support Java and Kotlin</p>

    ]]></description>

    <change-notes><![CDATA[
        <li>2.1.21 Major refactoring for IDE 2025.3 compatibility:<br/>
            - Replaced deprecated SimpleTreeBuilder with DefaultTreeModel for tree structure<br/>
            - Implemented multi-level tree: Module -> ServiceType(Rest/Feign) -> DownstreamService -> Endpoint<br/>
            - Fixed thread safety issues with runReadAction wrapper<br/>
            - Fixed DataKeys.MODULE API compatibility (use PlatformDataKeys.MODULE)<br/>
            - Improved Feign icon display using dedicated f.png icon<br/>
            - Added PluginLogger for unified logging
        </li>
        <li>2.1.20 Fixed RestServices tool window blank issue<br/>Used SimpleTreeBuilder correctly to connect tree data structure</li>
        <li>2.1.19 更新作者信息为billyle，保留原作者jinghong署名<br/>优化插件维护者信息</li>
                <li>2.1.18 修复Feign接口图标显示问题，正确区分Feign服务和普通Rest服务的图标<br/>在快速搜索框中添加服务类型筛选功能（Rest/Feign/All）</li>
        <li>2.1.17 新增Feign客户端支持，扩展RESTful服务发现能力<br/>优化服务解析器架构，提升多框架兼容性</li>
        <li>2.1.16 修复线程安全问题：解决"Save settings failed"错误，getState()方法现在正确处理非EDT线程调用</li>
        <li>2.1.15 完善模块名称显示功能，优化多项目环境下URL查找的准确性<br/>修复相关组件在复杂项目结构下的兼容性问题</li>
        <li>2.1.14 升级Java版本至17，修复IDE 2025.3版本兼容性问题<br/>在URL查找结果中显示所属模块名称，方便区分多项目中的相同URL</li>
        <li>2.0.9 在URL查找结果中显示所属模块名称，方便区分多项目中的相同URL<br/>扩展IDE兼容性至2025.3版本</li>
        <li>2.0.8 修复2022.3版本报错问题<br/>黑色主题下请求参数的面板也改为黑色</li>
        <li>2.0.7 Bug fixed</li>
        <li>2.0.6 Bug fixed, add Copy Query Param (Key Value)</li>
        <li>2.0.5 Bug fixed, supported http request OPTIONS,TRACE,CONNECT methods. </li>
        <li>2.0.4 Fixed NullPointerException with Kotlin project.<br/>
                  Fixed IllegalArgumentException: No enum constant com.zhaow.restful.method.HttpMethod.HEAD <br/>
                  Supported Kotlin 1.2 level. </li>
        <li>2.0.3 Improvements in navigate service(url), auto pasted copied http url to from clipboard.<br/>
                  Bug fixed.<br/> </li>
        <li>2.0.2 Match mapped URLs for Controllers without @RequestMapping annotations;<br/>
                  Supported mapped URLs for Controllers extended supper Object with @RequestMapping annotations.<br/>
                  Added Popup Menus ( "Copy Full Url", "Jump to Source") for service nodes.
        </li>
        <li>2.0.1 Fixed JSON generation issue with POJO contains array fields;
        </li>
        <li>2.0 Add Kotlin language supported;<br>
                Fixed some bugs.
        </li>
        <li>1.1 Supported JAX-RS;<br>
               Format JSON data , use "Command + Enter" on Mac
               (增强 POJO 生成 json 功能,处理 List、Enum等类型，处理自关联场景);<br>
               Fixed some bugs.<br>
       </li>
       <li>1.0.9 Service url navigation: matched restful style request mappings (e.g.:"/product/{productId}");<br>
       </li>
       <li>1.0.8 Bug fixed </li>
       <li>1.0.7 Match more mapped URLs ; (识别更多映射)<br>
                 Replaced icons;<br>
                 Add "Convert to JSON (Compressed)" function to java class;
       </li>
       <li>1.0.6 Compatible with IDEA 2016 (兼容 IDEA 2016) </li>
       <li>1.0.5 修复发送请求IDE卡死的问题. </li>
       <li>1.0.4 Format Date type (格式化 Date 类型) </li>
       <li>1.0.3 Small cleanup some code. </li>
    ]]>
    </change-notes>

    <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/build_number_ranges.html for description -->
    <idea-version since-build="173.0" until-build="253.*"/>

    <!-- please see http://www.jetbrains.org/intellij/sdk/docs/basics/getting_started/plugin_compatibility.html
         on how to target different products -->
    <!-- uncomment to enable plugin in all products
    <depends>com.intellij.modules.lang</depends>
    -->
    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.properties</depends>
    <depends>org.jetbrains.plugins.yaml</depends>
    <depends>org.jetbrains.kotlin</depends>

    <project-components>
        <component>
            <implementation-class>com.zhaow.restful.navigator.RestServicesNavigator</implementation-class>
        </component>
        <component>
            <implementation-class>com.zhaow.restful.navigator.RestServiceProjectsManager</implementation-class>
        </component>
        <!--        <component>
                    <implementation-class>com.zhaow.restful.navigation.action.GotoRequestMappingConfiguration</implementation-class>
                </component>-->
        <component>
            <implementation-class>com.zhaow.restful.navigator.RestServiceDetail</implementation-class>
        </component>
    </project-components>


    <extensions defaultExtensionNs="com.intellij">
        <projectService serviceImplementation="com.zhaow.restful.navigation.action.GotoRequestMappingConfiguration"/>
        <projectService serviceImplementation="com.zhaow.restful.navigation.action.GotoRequestMappingServiceTypeConfiguration"/>
        <tipAndTrick feature-id="navigation.popup.service" file="GotoService.html"/>
    </extensions>

    <application-components>
        <!-- Add your application components here -->
    </application-components>


    <actions>
        <action id="Popup.PopupChoiceAction"
                class="com.zhaow.restful.popup.action.PopupChoiceAction"
                text="Popup RESTful Toolkit ..."
                description="Popup RESTful Toolkit ...">
            <add-to-group group-id="EditMenu" anchor="last"/>
            <keyboard-shortcut keymap="$default" first-keystroke="alt shift R"/>
        </action>

        <!--在controller method 中添加 RestfulToolkit 弹出操作，generate rest url、generate rest url with Possibly params （添加可能的参数，解析实体，@RequestBody）、gen json、
        gen key value for postman(postman 参数bulk edit)、 gen key value for apiview submit -->
        <!--rest 方法中添加-->
        <group id="RestfulToolkitGroup" text="RestfulToolkit"
               description="RESTful Toolkit actions for rest method group"
        >
            <!--<add-to-group group-id="EditorPopupMenu" anchor="first"/>-->
            <action class="com.zhaow.restful.method.action.GenerateFullUrlAction" id="GenerateFullRestUrl"
                    text="Generate &amp;&amp; Copy Full URL">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <action class="com.zhaow.restful.method.action.GenerateUrlAction" id="GenerateRestUrl"
                    text="Generate &amp;&amp; Copy Relation URL">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <action class="com.zhaow.restful.method.action.GenerateQueryParamJsonAction" id="GenerateRequestBodyJson"
                    text="Generate &amp;&amp; Copy RequestBody (JSON)">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <action class="com.zhaow.restful.method.action.GenerateQueryParamAction" id="BuildQueryParam"
                    text="Generate &amp;&amp; Copy Query Param (Key Value)">
                <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            </action>
            <!--jaxrs-->

        </group>


        <group id="RestfulToolkit.RestMethod.EditorPopupMenu" text="RESTful Toolkit"
               description="RESTful Toolkit"
               popup="false">
            <!--<add-to-group group-id="EditorPopupMenu" anchor="last" relative-to-action="EditorToggleColumnMode"/>-->
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
            <!--<reference ref="GenerateRestUrl"/>-->
        </group>


        <!--实体中添加 gen json、
        gen key value for postman( postman 参数 bulk edit )-->


        <!--跳转导航： 根据rest url 导航 参考 request mapper  ( Enter mapping url ) 快捷键用 ctl alt n -->

        <!-- show services -->
        <action id="ConvertClassToJSONAction" class="com.zhaow.restful.action.ConvertClassToJSONAction"
                text="Convert to JSON" description="Convert to JSON">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>

        <action id="ConvertClassToJSONCompressedAction"
                class="com.zhaow.restful.action.ConvertClassToJSONCompressedAction" text="Convert to JSON (Compressed)"
                description="Convert to JSON (Compressed)">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>

        <action id="ConvertClassToBulkValueAction" class="com.zhaow.restful.action.ConvertClassToBulkValueAction"
                text="Convert to Bulk Value" description="Convert to Bulk Value">
            <add-to-group group-id="EditorPopupMenu" anchor="first"/>
        </action>

        <!-- url 导航 -->
        <action id="Toolkit.GotoService" class="com.zhaow.restful.navigation.action.GotoRequestMappingWithServiceTypeAction"
                text="_Service" description="Go to Service"
                icon="AllIcons.Actions.Search">
            <add-to-group group-id="GoToTargetEx" anchor="first"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl BACK_SLASH"/>
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt N"/>
        </action>

        <!--code gen-->
        <!--
              <action class="com.zhaow.restful.codegen.SpringBootGenerator" id="CodeGen"
                      text="SpringBoot Generator"
                      description="SpringBoot Generator">
                  <add-to-group group-id="GenerateGroup" anchor="first"/>
              </action>
        -->

        <!--刷新-->
        <action id="Toolkit.RefreshServices" class="com.zhaow.restful.navigator.RefreshProjectAction"
                text="Refresh Services in Project"
                icon="AllIcons.Actions.Refresh">
        </action>

        <group id="Toolkit.NavigatorActionsToolbar">
            <reference id="Toolkit.RefreshServices"/>
            <separator/>
            <reference id="Toolkit.GotoService"/>
            <separator/>
        </group>

        <group id="Toolkit.NavigatorServiceMenu">
            <action id="Menu.CopyFullUrlAction" class="com.zhaow.restful.navigator.CopyFullUrlAction"
                    text="Copy Full Url"
                    icon="AllIcons.Actions.Copy">
            </action>
            <action id="Menu.EditSourceAction" class="com.zhaow.restful.navigator.EditSourceAction"
                    text="Jump to Source"
                    icon="AllIcons.Actions.EditSource">
            </action>
            <separator/>
        </group>

        <!--      <action id="SpringBootAppRunnerAction" class="com.zhaow.restful.runner.SpringBootAppRunnerAction" text="SpringBootAppRunnerAction"
                      description="SpringBootAppRunnerAction">
                  &lt;!&ndash;<add-to-group group-id="RunnerActions" anchor="after" relative-to-action=""/>&ndash;&gt;
                  <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewDir"/>
              </action>
              -->

    </actions>
    <projectListeners>
        <listener class="com.zhaow.restful.navigator.MyToolwindowListener" topic="com.intellij.openapi.wm.ex.ToolWindowManagerListener" />
    </projectListeners>
</idea-plugin>
